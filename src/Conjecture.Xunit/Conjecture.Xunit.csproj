<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>xUnit v2 adapter for Conjecture property-based testing.</Description>
    <PackageTags>property-based-testing;testing;hypothesis;dotnet;xunit</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    <PackageReference Include="Microsoft.DotNet.ApiCompat.Task" PrivateAssets="all" />
  </ItemGroup>

  <PropertyGroup>
    <ApiCompatEnableRuleAttributesMustMatch>true</ApiCompatEnableRuleAttributesMustMatch>
    <ApiCompatBaseline>$(MSBuildThisFileDirectory)..\api-baseline\Conjecture.Xunit.dll</ApiCompatBaseline>
    <ApiCompatTreatIssuesAsErrors>false</ApiCompatTreatIssuesAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.extensibility.core" />
    <PackageReference Include="xunit.extensibility.execution" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Conjecture.Core\Conjecture.Core.csproj" />
    <ProjectReference Include="..\Conjecture.Testing.Abstractions\Conjecture.Testing.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Conjecture.Tests</_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Conjecture.Xunit.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

</Project>
