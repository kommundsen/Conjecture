<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>MSTest adapter for Conjecture.NET property-based testing</Description>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    <PackageReference Include="Microsoft.DotNet.ApiCompat.Task" PrivateAssets="all" />
    <PackageReference Include="MSTest.TestFramework" />
  </ItemGroup>

  <PropertyGroup>
    <ApiCompatEnableRuleAttributesMustMatch>true</ApiCompatEnableRuleAttributesMustMatch>
    <ApiCompatBaseline>$(MSBuildThisFileDirectory)..\api-baseline\Conjecture.MSTest.dll</ApiCompatBaseline>
    <ApiCompatTreatIssuesAsErrors>false</ApiCompatTreatIssuesAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Conjecture.Core\Conjecture.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Conjecture.MSTest.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

</Project>
