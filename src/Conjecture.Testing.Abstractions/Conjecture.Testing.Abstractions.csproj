<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <Description>Test-framework adapter contracts for Conjecture property-based testing. Reference this when building a custom test framework adapter (e.g. Conjecture.SomeUnit); end-user test code should reference an existing adapter (Conjecture.Xunit, Conjecture.NUnit, etc.) instead.</Description>
    <PackageTags>property-based-testing;testing;hypothesis;dotnet;abstractions;extension-author</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Conjecture.Core.Abstractions\Conjecture.Core.Abstractions.csproj" />
  </ItemGroup>

</Project>
