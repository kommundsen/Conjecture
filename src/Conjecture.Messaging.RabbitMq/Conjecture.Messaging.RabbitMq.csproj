<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>RabbitMQ adapter for Conjecture messaging property tests.</Description>
    <PackageTags>property-based-testing;testing;hypothesis;dotnet;messaging;rabbitmq;amqp</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Include="PublicAPI.Shipped.txt" />
    <None Include="PublicAPI.Unshipped.txt" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="RabbitMQ.Client" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Conjecture.Messaging\Conjecture.Messaging.csproj" />
  </ItemGroup>

</Project>
