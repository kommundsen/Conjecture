<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <Description>Interaction and state-machine contracts for Conjecture property-based testing. Reference this when building a transport bridge (e.g. Conjecture.Dapper); end-user test code should reference Conjecture.Interactions instead.</Description>
    <PackageTags>property-based-testing;testing;hypothesis;dotnet;abstractions;extension-author</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Conjecture.Core.Abstractions\Conjecture.Core.Abstractions.csproj" />
    <ProjectReference Include="..\Conjecture.Core\Conjecture.Core.csproj" />
  </ItemGroup>

</Project>
