<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <Description>Schema-format adapter contracts for Conjecture property-based testing. Reference this when building a new schema-format adapter (e.g. YAML schema); end-user test code should reference Conjecture.JsonSchema instead.</Description>
    <PackageTags>property-based-testing;testing;hypothesis;dotnet;abstractions;extension-author</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Conjecture.Core.Abstractions\Conjecture.Core.Abstractions.csproj" />
  </ItemGroup>

</Project>
