<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>JSON Schema-driven generation for Conjecture property-based testing.</Description>
    <PackageTags>property-based-testing;testing;hypothesis;dotnet;json-schema;json</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Conjecture.Core\Conjecture.Core.csproj" />
    <ProjectReference Include="..\Conjecture.JsonSchema.Abstractions\Conjecture.JsonSchema.Abstractions.csproj" />
    <ProjectReference Include="..\Conjecture.Regex\Conjecture.Regex.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Conjecture.JsonSchema.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

</Project>
