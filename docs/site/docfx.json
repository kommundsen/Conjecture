{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "Conjecture.Core/Conjecture.Core.csproj",
            "Conjecture.Xunit/Conjecture.Xunit.csproj",
            "Conjecture.Xunit.V3/Conjecture.Xunit.V3.csproj",
            "Conjecture.NUnit/Conjecture.NUnit.csproj",
            "Conjecture.MSTest/Conjecture.MSTest.csproj"
          ],
          "src": "../../src"
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "namespaceLayout": "nested",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      { "files": ["**/*.yml", "**/*.md"], "src": "api", "dest": "api" },
      { "files": ["articles/**/*.md", "articles/**/toc.yml"] },
      { "files": ["*.md", "toc.yml"] }
    ],
    "resource": [
      { "files": ["images/**"] }
    ],
    "dest": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "Conjecture.NET",
      "_appFooter": "Conjecture.NET &mdash; Property-based testing for .NET",
      "_enableSearch": true
    }
  }
}
